# Telegram
API_ID=12345678
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token
CHANNEL_ID=@yourchannel

# Apify
APIFY_TOKEN=apify_api_xxxxxxxxxxxx
MAX_RESULTS=5

# Deal filter
MIN_DISCOUNT=10

# Keywords (comma separated)
KEYWORDS=smartphone deals,earbuds offer,smartwatch sale,laptop offer

# Post times IST (24h)
MORNING_HOUR=9
EVENING_HOUR=20

# Render
PORT=8000
PYTHONUNBUFFERED=1
