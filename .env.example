# ── Telegram ──────────────────────────────────────────────
# Get from https://my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_here

# Get from @BotFather on Telegram
BOT_TOKEN=123456789:ABCDEFGHijklmnopqrstuvwxyz

# Your Telegram channel (where deals get posted)
# Use username like @mydeals OR numeric ID like -1001234567890
CHANNEL_ID=@your_channel_username

# Your personal Telegram user ID (for admin commands)
# Get it from @userinfobot
OWNER_ID=123456789

# ── Apify ─────────────────────────────────────────────────
# Get from https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# How many Amazon products to fetch per search (keep 5 on free plan)
MAX_RESULTS=5

# ── MongoDB ───────────────────────────────────────────────
# MongoDB Atlas free cluster URI
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=apify_bot

# ── Redis ─────────────────────────────────────────────────
# Upstash free Redis URI (works great on Render)
REDIS_URL=redis://default:password@your-redis-host.upstash.io:6379

# ── Scheduler & Deals ─────────────────────────────────────
# How often to auto-post deals (in hours)
AUTO_POST_INTERVAL_HOURS=6

# Comma-separated keywords for auto deal posts
DEFAULT_DEAL_KEYWORDS=smartphone deals,earbuds offer,smartwatch sale,laptop offer

# Minimum discount % to show a product as a "deal"
MIN_DISCOUNT_PERCENT=10

# How long to cache search results in seconds (3600 = 1 hour)
CACHE_TTL=3600
